[common]
# 基础设置
api_url = http://127.0.0.1:25500
dns_listen = 0.0.0.0:53
dns_enable = true
dns_fake_ip = true

# 节点排除过滤 (对应你 yaml 中的 exclude-filter)
exclude_remarks = (家宽|冷门|重置|剩余|到期|x|X|网址|Lite|lite)

[proxy_group]
# --- 1. 核心选择组 ---
🚀 节点选择:select, ♻️ 自动选择, ♻️ 自动选择2, ✈️ 手动选择, 🔮 负载均衡, 🇭🇰 香港节点, 🇨🇳 台湾节点, 🇸🇬 狮城节点, 🇯🇵 日本节点, 🇺🇲 美国节点, 📺 Emby专用节点, DIRECT
✈️ 手动选择:select, .*
🔮 负载均衡:load-balance, .*, http://www.gstatic.com/generate_204, 150, consistent-hashing

# --- 2. 自动化组 ---
♻️ 自动选择:url-test, .*, http://www.gstatic.com/generate_204, 300,, 50
# 自动选择2 仅限订阅源A（假设第一个订阅为A）
♻️ 自动选择2:url-test, !!GROUP:A, http://www.gstatic.com/generate_204, 300,, 50

# --- 3. 业务逻辑组 ---
🎯 国内流量:select, DIRECT, 🚀 节点选择
💬 Ai:select, []filter:美|波特兰|达拉斯|俄勒冈|凤凰城|费利蒙|硅谷|拉斯维加斯|洛杉矶|圣何塞|圣克拉拉|西雅图|芝加哥|US|United States|日本|川日|东京|大阪|泉日|埼玉|🇭🇰|HK|新加坡|SG
📹 YouTube:select, 🚀 节点选择, ♻️ 自动选择
🎥 Netflix:select, 🇭🇰 香港节点, 🇨🇳 台湾节点, 🇸🇬 狮城节点, 🚀 节点选择
🎬 EMBY:select, 📺 Emby专用节点, ♻️ 自动选择, 🇭🇰 香港节点, ✈️ 手动选择
🎵 Spotify:select, 🚀 节点选择, 🇸🇬 狮城节点, 🎯 国内流量
🎶 TikTok:select, 🚀 节点选择, 🇸🇬 狮城节点, 🇯🇵 日本节点
🌍 国外媒体:select, 🚀 节点选择, 🎯 国内流量
🌏 国内媒体:select, 🎯 国内流量, DIRECT
📲 Telegram:select, 🚀 节点选择, 🇸🇬 狮城节点
👨‍💻 GitHub:select, 🚀 节点选择, 🎯 国内流量
🍎 苹果服务:select, DIRECT, 🎯 国内流量, 🚀 节点选择
Ⓜ️ 微软云盘:select, DIRECT, 🚀 节点选择
Ⓜ️ 微软服务:select, DIRECT, 🎯 国内流量
🐟 漏网之鱼:select, 🚀 节点选择, DIRECT, 🎯 国内流量

# --- 4. 区域优选组 ---
🇭🇰 香港节点:url-test, (港|HK|hk|Hong Kong|HongKong), http://www.gstatic.com/generate_204, 300,, 50
🇨🇳 台湾节点:url-test, (台|新北|彰化|TW|Taiwan), http://www.gstatic.com/generate_204, 300,, 50
🇸🇬 狮城节点:url-test, (新加坡|坡|狮城|SG|Singapore), http://www.gstatic.com/generate_204, 300,, 50
🇯🇵 日本节点:url-test, (日本|JP|Japan), http://www.gstatic.com/generate_204, 300,, 50
🇺🇲 美国节点:url-test, (美|US|United States), http://www.gstatic.com/generate_204, 300,, 50
📺 Emby专用节点:url-test, []exclude:pro|Lite|lite, http://www.gstatic.com/generate_204, 300,, 50

